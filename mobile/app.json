{
  "expo": {
    "name": "Smakuje",
    "slug": "smakuje",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "smakuje",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF6F0"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "pl.smakuje.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Zrób zdjęcie dania",
        "NSPhotoLibraryUsageDescription": "Wybierz zdjęcie dania z galerii"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FAF6F0"
      },
      "package": "pl.smakuje.app",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-image-picker"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a2225528-6686-4d41-8816-cb2404a0aa57"
      }
    },
    "owner": "lemonadaqs-team"
  }
}
